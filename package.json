{
  "name": "napi-blitz-workspace",
  "version": "1.1.1",
  "private": true,
  "description": "Workspace for napi-blitz and wasm-blitz packages",
  "repository": {
    "url": "git+ssh://git@github.com/jerry4718/napi-blitz.git",
    "type": "git"
  },
  "license": "MIT",
  "scripts": {
    "artifacts": "pnpm --filter @ylcc/napi-blitz artifacts",
    "bench": "node --import @oxc-node/core/register benchmark/bench.ts",
    "build": "node scripts/build.cjs",
    "build:debug": "node scripts/build.cjs --debug",
    "build:native": "node scripts/build.cjs --native-only",
    "build:native:debug": "node scripts/build.cjs --debug --native-only",
    "build:ts": "pnpm -r --filter './packages/*' run build:ts",
    "test": "ava",
    "fmt": "cargo fmt",
    "fmt:check": "cargo fmt -- --check",
    "lint": "cargo clippy",
    "lint:strict": "cargo clippy -- -D warnings",
    "version": "pnpm --filter @ylcc/napi-blitz version"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.2",
    "@oxc-node/core": "^0.1.0",
    "@types/node": "^25.9.3",
    "ava": "^6.4.1",
    "cross-env": "^10.1.0",
    "typescript": "^5.9.3"
  },
  "ava": {
    "extensions": {
      "ts": "module"
    },
    "files": [
      "__test__/**/*.spec.ts"
    ],
    "timeout": "2m",
    "workerThreads": false,
    "environmentVariables": {
      "TS_NODE_PROJECT": "./tsconfig.json"
    },
    "nodeArguments": [
      "--import",
      "@oxc-node/core/register"
    ]
  },
  "packageManager": "pnpm@11.8.0"
}
