{
  "name": "@ylcc/napi-blitz",
  "version": "1.1.1",
  "description": "blitz napi bindings",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "url": "git+ssh://git@github.com/jerry4718/napi-blitz.git",
    "type": "git"
  },
  "license": "MIT",
  "keywords": [
    "napi-rs",
    "NAPI",
    "N-API",
    "node-addon",
    "node-addon-api",
    "blitz"
  ],
  "files": [
    "dist/",
    "native/"
  ],
  "napi": {
    "binaryName": "napi-blitz",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "i686-pc-windows-msvc",
      "armv7-unknown-linux-gnueabihf",
      "x86_64-unknown-freebsd",
      "aarch64-unknown-linux-musl",
      "aarch64-pc-windows-msvc"
    ]
  },
  "engines": {
    "node": ">= 10"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "bench": "node --import @oxc-node/core/register benchmark/bench.ts",
    "build": "pnpm run build:native && pnpm run build:ts",
    "build:debug": "pnpm run build:native:debug && pnpm run build:ts",
    "build:ts": "tsc -p tsconfig.json && pnpm run build:ts:fixup",
    "build:ts:fixup": "node -e \"const fs=require('fs');const p='dist/native.d.ts';fs.writeFileSync(p,fs.readFileSync(p,'utf8').replace(/from \\\"\\.\\.\\/\\.\\.\\/native\\\"/g,'from \\\"../native\\\"'));\"",
    "build:native": "napi build --platform --release --strip --output-dir native --js index.js --dts index.d.ts",
    "build:native:debug": "napi build --platform --strip --output-dir native --js index.js --dts index.d.ts",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "ava",
    "fmt": "cargo fmt",
    "fmt:check": "cargo fmt -- --check",
    "lint": "cargo clippy",
    "lint:strict": "cargo clippy -- -D warnings",
    "version": "napi version"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.2",
    "@oxc-node/core": "^0.1.0",
    "@types/node": "^25.9.3",
    "ava": "^6.4.1",
    "cross-env": "^10.1.0",
    "typescript": "^5.9.3"
  },
  "ava": {
    "extensions": {
      "ts": "module"
    },
    "files": [
      "__test__/**/*.spec.ts"
    ],
    "timeout": "2m",
    "workerThreads": false,
    "environmentVariables": {
      "TS_NODE_PROJECT": "./tsconfig.json"
    },
    "nodeArguments": [
      "--import",
      "@oxc-node/core/register"
    ]
  },
  "packageManager": "pnpm@11.8.0"
}
